PORT=3001
CORS_ORIGIN=http://localhost:4200

# For Firestore Admin SDK (choose one):
# Option A: provide a service account JSON file path
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# Option B: if you use a different credential mechanism, set the needed env vars accordingly.

# Firestore collection name (default: "cars")
FIRESTORE_COLLECTION=cars

